# Kopieer dit bestand naar .env en vul de waarden in
PORT=3000
NODE_ENV=production

# Genereer een willekeurig lang geheim, bijv:
#   openssl rand -base64 48
JWT_SECRET=verander_dit_naar_een_lang_willekeurig_geheim

# Automatic face blur on photo upload (requires face-api models in server/models/)
# Run `node server/scripts/download-models.js` first, then set to true to enable
FACE_BLUR_ENABLED=false
# Face matching sensitivity (euclidean distance). Default: 0.6
# 0.4=strict (frontal only)  0.5=balanced  0.6=lenient  0.7=very lenient (false positive risk)
FACE_BLUR_THRESHOLD=0.6

# Social media embeds in reel player (TikTok / Instagram iframes)
# Set to false to hide all social embeds globally without deleting linked URLs
SOCIAL_EMBEDS_ENABLED=true

# Cloudflare Tunnel token
# Aanmaken via: https://one.dash.cloudflare.com → Networks → Tunnels → Create a tunnel
# Kies "Cloudflared" → kopieer het token uit de installatiestap
CLOUDFLARE_TUNNEL_TOKEN=plak_hier_je_tunnel_token

# ── Raspberry Pi pull-script (scripts/pull-from-pi.ps1) ──────────────────────
# Vul in om productie-content naar lokaal te kopiëren
PI_HOST=192.168.1.x
PI_USER=pi
PI_PATH=/home/pi/Team
